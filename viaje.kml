  <Document>
    <name>Roma + Costa Amalfitana (7 – 16 julio 2026)</name>
    <description>Todos los puntos del viaje, generados desde el itinerario.</description>
    <Folder>
      <name>Día 0 · Llegada a Roma</name>
      <Placemark>
        <name>Fontana di Trevi</name>
        <description>🕒 20:30  ⏱ 30min  💶 Gratis  
La fuente barroca más famosa de Roma, espectacular de noche.  
🚶 A pie.</description>
        <Point><coordinates>12.483313,41.9009325,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Panteón de Roma</name>
        <description>🕒 21:15  ⏱ 30min  💶 Gratis (exterior de noche)  
El Panteón iluminado y la Piazza della Rotonda.  
🚶 A pie.</description>
        <Point><coordinates>12.4768729,41.8986108,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Cena por el centro</name>
        <description>🕒 21:45  ⏱ 1h30  💶 ~30 €/pers.  
Primera cena romana: cacio e pepe, carbonara, supplì.  
🚶 A pie.</description>
        <Point><coordinates>12.476,41.8986,0</coordinates></Point>
      </Placemark>
    </Folder>
    <Folder>
      <name>Día 1 · La Roma antigua</name>
      <Placemark>
        <name>Coliseo de Roma</name>
        <description>🕒 09:00  ⏱ 1h30  💶 18 € (combinado)  
Anfiteatro Flavio: gradas, arena y subterráneos.  
🚶 Metro línea B, parada Colosseo.</description>
        <Point><coordinates>12.4922309,41.8902102,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Arco de Constantino</name>
        <description>🕒 10:30  ⏱ 15min  💶 Gratis  
Arco triunfal del s. IV junto al Coliseo.  
🚶 A pie.</description>
        <Point><coordinates>12.4906782,41.8898113,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Foro Romano</name>
        <description>🕒 10:50  ⏱ 1h15  💶 Incluido  
Vía Sacra, templos, Curia, Arco de Tito.  
🚶 A pie (misma entrada combinada).</description>
        <Point><coordinates>12.4864378,41.8920906,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Monte Palatino</name>
        <description>🕒 12:10  ⏱ 50min  💶 Incluido  
Palacios imperiales y vistas sobre el Circo Máximo.  
🚶 A pie, conectado con el Foro.</description>
        <Point><coordinates>12.4833333,41.8833333,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Circo Máximo</name>
        <description>🕒 13:05  ⏱ 20min  💶 Gratis  
Antiguo circo de carreras de cuádrigas; gran explanada.  
🚶 A pie bajando del Palatino.</description>
        <Point><coordinates>12.4857578,41.8858762,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Comida (zona Aventino/Circo)</name>
        <description>🕒 13:30  ⏱ 1h  💶 ~18 €/pers.  
Pausa para comer.  
🚶 A pie.</description>
        <Point><coordinates>12.483,41.8845,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Termas de Caracalla</name>
        <description>🕒 14:45  ⏱ 1h  💶 8 €  
Enormes termas imperiales del s. III.  
🚶 A pie / bus desde el Circo Máximo.</description>
        <Point><coordinates>12.4924394,41.8790382,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Monumento a Víctor Manuel II (Vittoriano)</name>
        <description>🕒 16:15  ⏱ 40min  💶 Gratis  
El &apos;Altar de la Patria&apos;; terraza panorámica.  
🚶 Bus / a pie a Piazza Venezia.</description>
        <Point><coordinates>12.4831269,41.8945976,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Plaza Venezia</name>
        <description>🕒 16:55  ⏱ 15min  💶 Gratis  
Plaza neurálgica de Roma a los pies del Vittoriano.  
🚶 A pie.</description>
        <Point><coordinates>12.4825739,41.8957663,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Estatua de Rómulo y Remo (Loba Capitolina)</name>
        <description>🕒 17:15  ⏱ 10min  💶 Gratis  
La loba amamantando a Rómulo y Remo, en el Campidoglio.  
🚶 A pie subiendo al Campidoglio.</description>
        <Point><coordinates>12.4836287,41.8933676,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Estatua ecuestre de Marco Aurelio</name>
        <description>🕒 17:25  ⏱ 10min  💶 Gratis  
Réplica en la Plaza del Campidoglio (diseño de Miguel Ángel).  
🚶 A pie.</description>
        <Point><coordinates>12.4829349,41.8933247,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Museos Capitolinos</name>
        <description>🕒 17:40  ⏱ 1h15  💶 16 €  
Loba Capitolina original, escultura clásica y vistas del Foro.  
🚶 En la Plaza del Campidoglio.</description>
        <Point><coordinates>12.4825577,41.8929428,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>San Pietro in Vincoli</name>
        <description>🕒 19:05  ⏱ 25min  💶 Gratis  
El Moisés de Miguel Ángel.  
🚶 A pie.</description>
        <Point><coordinates>12.4931498,41.8937984,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Santa Maria della Neve (Santa Maria Maggiore)</name>
        <description>🕒 19:40  ⏱ 25min  💶 Gratis  
Basílica papal con mosaicos paleocristianos.  
🚶 A pie.</description>
        <Point><coordinates>12.4984084,41.8975986,0</coordinates></Point>
      </Placemark>
      <Placemark>
        <name>Cena por Monti</name>
        <description>🕒 21:00  ⏱ 1h30  💶 ~30 €/pers.  
Cena en el barrio de Monti.  
🚶 A pie.</description>
        <Point><coordinates>12.493,41.8946,0</coordinates></Point>
      </Placemark>
    </Folder>
